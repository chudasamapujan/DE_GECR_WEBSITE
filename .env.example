# ==========================================
# GEC Rajkot Environment Configuration
# ==========================================
# Copy this file to .env and fill in your actual values

# Flask Configuration
SECRET_KEY=your-secret-key-here-change-this-in-production
JWT_SECRET_KEY=your-jwt-secret-key-here-change-this-in-production

# Database Configuration
DATABASE_URL=sqlite:///gec_rajkot.db

# Gmail SMTP Configuration for OTP Emails
# To use Gmail SMTP, you need to:
# 1. Enable 2-Factor Authentication on your Gmail account
# 2. Generate an App Password: https://myaccount.google.com/apppasswords
# 3. Use the App Password (16 characters without spaces) as MAIL_PASSWORD

MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-16-character-app-password
MAIL_DEFAULT_SENDER=your-email@gmail.com

# SendGrid Configuration (Optional - Alternative to Gmail SMTP)
# SENDGRID_API_KEY=your-sendgrid-api-key-here

# College Information
COLLEGE_NAME=Government Engineering College, Rajkot
COLLEGE_EMAIL=info@gecrajkot.ac.in

# Application Settings
FLASK_ENV=development
DEBUG=True
